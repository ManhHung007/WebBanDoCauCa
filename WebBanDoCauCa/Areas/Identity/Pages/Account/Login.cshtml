@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card shadow border-0 p-4" style="width: 420px; border-radius: 12px;">

        <h2 class="text-center fw-bold mb-4">ĐĂNG NHẬP</h2>

        <form id="account" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <input asp-for="Input.Email"
                       class="form-control form-control-lg"
                       placeholder="Email đăng nhập" />

                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <input asp-for="Input.Password"
                       class="form-control form-control-lg"
                       placeholder="Mật khẩu" />

                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-check mb-4">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">
                    Ghi nhớ đăng nhập
                </label>
            </div>

            <button type="submit"
                    class="btn w-100 fw-bold text-dark"
                    style="background-color: #ffc107; height: 50px; font-size: 18px;">
                ĐĂNG NHẬP
            </button>

            <div class="text-center mt-4">
                <span class="text-muted">Chưa có tài khoản?</span>
                <br />
                <a asp-page="/Account/Register"
                   style="color: #ffc107; font-weight: bold; text-decoration: none;">
                    Đăng ký ngay
                </a>
            </div>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}