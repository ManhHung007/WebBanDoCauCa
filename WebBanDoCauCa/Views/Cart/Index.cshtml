@model IEnumerable<WebBanDoCauCa.Models.CartItem>

@{
    ViewData["Title"] = "Giỏ hàng của bạn";
}

<div class="container mt-4">
    <h2 class="fw-bold text-primary mb-4"><i class="fa-solid fa-cart-shopping"></i> GIỎ HÀNG CỦA BẠN</h2>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle bg-white">
                <thead class="table-dark">
                    <tr>
                        <th>Hình ảnh</th>
                        <th>Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end">Thành tiền</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr id="cart-item-@item.Id">
                            <td>
                                <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name" class="img-thumbnail" style="width: 80px; height: 80px; object-fit: contain;">
                            </td>
                            <td>
                                <div class="fw-bold text-dark">@item.Product?.Name</div>
                            </td>
                            <td class="text-center">
                                <input type="number" value="@item.Quantity" min="1" class="form-control form-control-sm mx-auto quantity-input"
                                       data-id="@item.Id" style="width: 60px;">
                            </td>
                            <td class="text-end">@item.Product?.Price.ToString("N0") VNĐ</td>
                            <td class="text-end fw-bold">@((item.Quantity * (item.Product?.Price ?? 0)).ToString("N0")) VNĐ</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-danger remove-item" data-id="@item.Id">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="d-flex justify-content-between mt-4 mb-5">
            <a class="btn btn-outline-secondary fw-bold" asp-controller="Products" asp-action="Index">
                <i class="fa-solid fa-arrow-left"></i> TIẾP TỤC MUA SẮM
            </a>
            <a class="btn btn-success btn-lg px-5 fw-bold shadow" asp-controller="Checkout" asp-action="Index">
                TIẾN HÀNH THANH TOÁN <i class="fa-solid fa-credit-card ms-2"></i>
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center py-5">
            <i class="fa-solid fa-cart-arrow-down fa-3x mb-3"></i>
            <h4>Giỏ hàng của bạn đang trống!</h4>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-3">Quay lại mua sắm</a>
        </div>
    }
</div>

@section Scripts {
    <script>
        // Xử lý Xóa sản phẩm
        $('.remove-item').click(function() {
            var id = $(this).data('id');
            $.post('/Cart/RemoveItem', { id: id }, function() {
                location.reload(); // Tải lại trang để cập nhật tổng tiền
            });
        });

        // Xử lý Thay đổi số lượng
        $('.quantity-input').change(function() {
            var id = $(this).data('id');
            var qty = $(this).val();
            $.post('/Cart/UpdateQuantity', { id: id, quantity: qty }, function() {
                location.reload();
            });
        });
    </script>
}