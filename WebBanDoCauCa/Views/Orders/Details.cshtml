@model WebBanDoCauCa.Models.Order

@{
    ViewData["Title"] = "Chi tiết đơn hàng";
}

<div class="container mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">
            <i class="fa-solid fa-receipt text-warning"></i>
            Chi tiết đơn hàng #@Model.Id
        </h2>

        <a asp-controller="Orders"
           asp-action="Index"
           class="btn btn-dark">
            <i class="fa-solid fa-arrow-left"></i>
            Quay lại
        </a>
    </div>

    <div class="card shadow border-0 rounded-4 mb-4">
        <div class="card-body p-4">

            <div class="row">
                <div class="col-md-6">
                    <p>
                        <strong>Khách hàng:</strong>
                        @Model.CustomerName
                    </p>

                    <p>
                        <strong>Số điện thoại:</strong>
                        @Model.Phone
                    </p>

                    <p>
                        <strong>Địa chỉ:</strong>
                        @Model.Address
                    </p>
                </div>

                <div class="col-md-6 text-md-end">
                    <p>
                        <strong>Trạng thái:</strong>

                        <span class="badge bg-warning text-dark px-3 py-2">
                            @Model.Status
                        </span>
                    </p>

                    <p class="fs-5 fw-bold text-danger">
                        Tổng tiền:
                        @Model.TotalAmount.ToString("N0") VNĐ
                    </p>
                </div>
            </div>

        </div>
    </div>

    <div class="card shadow border-0 rounded-4">
        <div class="card-header bg-dark text-white py-3 rounded-top-4">
            <h5 class="mb-0">
                <i class="fa-solid fa-box-open"></i>
                Sản phẩm trong đơn hàng
            </h5>
        </div>

        <div class="card-body p-0">

            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Sản phẩm</th>
                        <th class="text-center">Số lượng</th>
                        <th class="text-end">Đơn giá</th>
                        <th class="text-end pe-4">Thành tiền</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                    {
                        @foreach (var item in Model.OrderDetails)
                        {
                            <tr>

                                <td class="ps-4">

                                    <div class="d-flex align-items-center gap-3">

                                        <img src="@(item.Product?.ImageUrl ?? "/images/no-image.png")"
                                             width="70"
                                             height="70"
                                             style="object-fit:cover;border-radius:10px;border:1px solid #ddd;" />

                                        <div>
                                            <div class="fw-bold">
                                                @(item.Product?.Name ?? "Không có tên sản phẩm")
                                            </div>

                                            <small class="text-muted">
                                                Mã SP: @item.ProductId
                                            </small>
                                        </div>

                                    </div>

                                </td>

                                <td class="text-center fw-bold">
                                    x @item.Quantity
                                </td>

                                <td class="text-end">
                                    @item.Price.ToString("N0") VNĐ
                                </td>

                                <td class="text-end pe-4 fw-bold text-danger">
                                    @((item.Quantity * item.Price).ToString("N0")) VNĐ
                                </td>

                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4">
                                Không có sản phẩm trong đơn hàng
                            </td>
                        </tr>
                    }

                </tbody>
            </table>

        </div>
    </div>

</div>