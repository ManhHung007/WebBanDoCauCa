[Authorize(Roles = "Admin")]
public IActionResult Create()
{
    ViewData["CategoryId"] = new SelectList(_context.Categories, "Id", "Name");
    return View();
}

[HttpPost]
[ValidateAntiForgeryToken]
[Authorize(Roles = "Admin")]
public async Task<IActionResult>
    Create(Product product)
    {
    try
    {
    // =========================
    // 1. CHECK MODEL VALIDATION
    // =========================
    if (!ModelState.IsValid)
    {
    ViewData["CategoryId"] = new SelectList(_context.Categories, "Id", "Name", product.CategoryId);
    return View(product);
    }

    // =========================
    // 2. FIX NULL IMAGE
    // =========================
    product.ImageUrl = string.IsNullOrWhiteSpace(product.ImageUrl)
    ? ""
    : product.ImageUrl.Trim();

    // =========================
    // 3. CHECK CATEGORY EXISTS (FK SAFE)
    // =========================
    var categoryExists = await _context.Categories
    .AnyAsync(c => c.Id == product.CategoryId);

    if (!categoryExists)
    {
    ModelState.AddModelError("CategoryId", "Danh mục không tồn tại trong hệ thống");
    ViewData["CategoryId"] = new SelectList(_context.Categories, "Id", "Name", product.CategoryId);
    return View(product);
    }

    // =========================
    // 4. VALIDATE PRICE (TRÁNH LỖI INPUT)
    // =========================
    if (product.Price <= 0)
    {
    ModelState.AddModelError("Price", "Giá sản phẩm không hợp lệ");
    ViewData["CategoryId"] = new SelectList(_context.Categories, "Id", "Name", product.CategoryId);
    return View(product);
    }

    // =========================
    // 5. SALE LOGIC SAFE RESET
    // =========================
    if (!product.IsOnSale)
    {
    product.DiscountPercent = 0;
    product.SaleStartDate = null;
    product.SaleEndDate = null;
    }

    // =========================
    // 6. INSERT DB (SAFE)
    // =========================
    _context.Products.Add(product);
    await _context.SaveChangesAsync();

    return RedirectToAction(nameof(Index));
    }
    catch (DbUpdateException dbEx)
    {
    // 🔥 LỖI DATABASE (FK, NOT NULL, constraint)
    return StatusCode(500, $"Database error: {dbEx.InnerException?.Message ?? dbEx.Message}");
    }
    catch (Exception ex)
    {
    // 🔥 LỖI KHÁC
    return StatusCode(500, ex.ToString());
    }
    }
