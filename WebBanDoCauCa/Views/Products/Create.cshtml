@model WebBanDoCauCa.Models.Product

@{
    ViewData["Title"] = "Cập nhật thông tin sản phẩm";
}

<div class="card shadow-sm">
    <div class="card-header bg-primary text-white">
        <i class="fas fa-edit"></i> CẬP NHẬT THÔNG TIN SẢN PHẨM
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="row">
                <div class="col-md-3 text-center">
                    <label class="font-weight-bold">Hình ảnh hiện tại</label>
                    <div class="border p-2 mt-2">
                        <img id="previewImage" src="@(string.IsNullOrEmpty(Model?.ImageUrl) ? "https://via.placeholder.com/200" : Model.ImageUrl)"
                             class="img-fluid" alt="Product Image" onerror="this.src='https://via.placeholder.com/200'" />
                    </div>
                    <small class="text-muted d-block mt-2">Ảnh sẽ tự cập nhật khi nhập URL mới</small>
                </div>

                <div class="col-md-9">
                    <div class="form-group mb-3">
                        <label asp-for="Name" class="font-weight-bold">Tên sản phẩm</label>
                        <input asp-for="Name" class="form-control" placeholder="Nhập tên sản phẩm..." />
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="CategoryId" class="font-weight-bold">Danh mục</label>
                            <select asp-for="CategoryId" class="form-control" asp-items="ViewBag.CategoryId"></select>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label asp-for="Price" class="font-weight-bold">Giá bán (VNĐ)</label>
                            <input asp-for="Price" id="inputPrice" class="form-control" type="number" step="0.01" />
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ImageUrl" class="font-weight-bold">Đường dẫn ảnh (URL)</label>
                        <input asp-for="ImageUrl" id="inputImageUrl" class="form-control" placeholder="Dán link ảnh tại đây..." />
                    </div>

                    <div class="card bg-light mt-4">
                        <div class="card-header bg-warning font-weight-bold">
                            <i class="fas fa-tags"></i> Thiết lập khuyến mãi
                        </div>
                        <div class="card-body">
                            <div class="form-check form-switch mb-3">
                                <input class="form-check-input" asp-for="IsOnSale" id="saleToggle" type="checkbox">
                                <label class="form-check-label font-weight-bold" for="saleToggle">Áp dụng giảm giá cho sản phẩm</label>
                            </div>

                            <div id="saleDetails" style="display: @(Model?.IsOnSale == true ? "block" : "none")">
                                <div class="row">
                                    <div class="col-md-4 form-group">
                                        <label asp-for="DiscountPercent">Phần trăm giảm giá (%)</label>
                                        <input asp-for="DiscountPercent" id="inputDiscount" class="form-control" type="number" />
                                    </div>
                                    <div class="col-md-4 form-group">
                                        <label asp-for="SaleStartDate">Ngày bắt đầu</label>
                                        <input asp-for="SaleStartDate" class="form-control" type="datetime-local" />
                                    </div>
                                    <div class="col-md-4 form-group">
                                        <label asp-for="SaleEndDate">Ngày kết thúc</label>
                                        <input asp-for="SaleEndDate" class="form-control" type="datetime-local" />
                                    </div>
                                </div>
                                <div class="alert alert-success mt-3" id="pricePreview">
                                    Giá sau giảm: <strong id="calculatedPrice">0</strong> VNĐ
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                        <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> LƯU THAY ĐỔI</button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const toggle = document.getElementById('saleToggle');
        const details = document.getElementById('saleDetails');
        const priceInput = document.getElementById('inputPrice');
        const discountInput = document.getElementById('inputDiscount');
        const calcPrice = document.getElementById('calculatedPrice');
        const imgInput = document.getElementById('inputImageUrl');
        const imgPreview = document.getElementById('previewImage');

        // Logic Ẩn/Hiện
        toggle.addEventListener('change', () => details.style.display = toggle.checked ? 'block' : 'none');

        // Logic tự tính giá
        function updatePrice() {
            let p = parseFloat(priceInput.value) || 0;
            let d = parseFloat(discountInput.value) || 0;
            calcPrice.innerText = (p - (p * d / 100)).toLocaleString();
        }

        [priceInput, discountInput].forEach(el => el.addEventListener('input', updatePrice));
        imgInput.addEventListener('input', () => imgPreview.src = imgInput.value);
        updatePrice();
    </script>
}