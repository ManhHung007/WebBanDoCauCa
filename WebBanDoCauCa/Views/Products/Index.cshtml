@model IEnumerable<WebBanDoCauCa.Models.Product>
@{
    ViewData["Title"] = "Cửa hàng đồ câu";
    var categories = ViewBag.Categories as IEnumerable<WebBanDoCauCa.Models.Category>;
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5 class="fw-bold">Bộ lọc</h5>
                <hr>
                <div class="mb-3">
                    <label class="fw-bold">Danh mục</label>
                    @foreach (var cat in categories)
                    {
                        <div class="form-check">
                            <input class="form-check-input cat-filter" type="checkbox" value="@cat.Id" id="cat_@cat.Id">
                            <label class="form-check-label" for="cat_@cat.Id">@cat.Name</label>
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Giá: <span id="priceVal">0 - 5.000.000</span></label>
                    <input type="range" class="form-range" min="0" max="5000000" step="100000" id="priceRange">
                </div>
                <button class="btn btn-primary w-100" onclick="applyFilters()">Áp dụng lọc</button>
            </div>
        </div>

        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold">Sản phẩm</h4>
                <select class="form-select w-25" onchange="window.location.href='?sortOrder=' + this.value">
                    <option value="">Sắp xếp giá</option>
                    <option value="price_asc">Thấp đến cao</option>
                    <option value="price_desc">Cao đến thấp</option>
                </select>
            </div>

            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0">
                            <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:contain;">
                            <div class="card-body text-center">
                                <h6 class="fw-bold">@item.Name</h6>
                                <p class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</p>
                                <div class="d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                                    <button class="btn btn-warning btn-sm btn-add-to-cart" data-id="@item.Id">Thêm giỏ hàng</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // Xử lý slider giá
    document.getElementById('priceRange').oninput = function() {
        document.getElementById('priceVal').innerText = "0 - " + parseInt(this.value).toLocaleString();
    }

    function applyFilters() {
        let cats = [];
        $('.cat-filter:checked').each(function() { cats.push($(this).val()); });
        let maxPrice = $('#priceRange').val();
        window.location.href = `?categoryIds=${cats.join(',')}&maxPrice=${maxPrice}`;
    }
</script>