@model IEnumerable<WebBanDoCauCa.Models.Product>
@{
    ViewData["Title"] = "Cửa hàng đồ câu";
    var categories = ViewBag.Categories as IEnumerable<WebBanDoCauCa.Models.Category>;
}

@* Form ẩn để gửi Token chống tấn công CSRF *@
<form id="antiforgery-form" style="display:none;">@Html.AntiForgeryToken()</form>

<div class="container mt-4">
    <div class="row">
        @* SIDEBAR BỘ LỌC *@
        <div class="col-md-3">
            <div class="card p-3 shadow-sm">
                <h5 class="fw-bold">Bộ lọc</h5>
                <hr>
                <div class="mb-3">
                    <label class="fw-bold">Danh mục</label>
                    @foreach (var cat in categories)
                    {
                        <div class="form-check">
                            <input class="form-check-input cat-filter" type="checkbox" value="@cat.Id" id="cat_@cat.Id">
                            <label class="form-check-label" for="cat_@cat.Id">@cat.Name</label>
                        </div>
                    }
                </div>
                <div class="mb-3">
                    <label class="fw-bold">Giá tối đa: <span id="priceVal">5.000.000</span></label>
                    <input type="range" class="form-range" min="0" max="5000000" step="100000" id="priceRange">
                </div>
                <button class="btn btn-primary w-100" onclick="applyFilters()">Áp dụng lọc</button>
            </div>
        </div>

        @* DANH SÁCH SẢN PHẨM *@
        <div class="col-md-9">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="fw-bold">Sản phẩm</h4>
                <select id="sortOrder" class="form-select w-25" onchange="applyFilters()">
                    <option value="">Sắp xếp giá</option>
                    <option value="price_asc">Thấp đến cao</option>
                    <option value="price_desc">Cao đến thấp</option>
                </select>
            </div>

            <div class="row">
                @foreach (var item in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm border-0">
                            <img src="@item.ImageUrl" class="card-img-top" style="height:200px; object-fit:contain;">
                            <div class="card-body text-center">
                                <h6 class="fw-bold">@item.Name</h6>
                                <p class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</p>
                                <div class="d-grid gap-2">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                                    <button class="btn btn-warning btn-sm btn-add-to-cart" data-id="@item.Id">Thêm giỏ hàng</button>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    $(document).ready(function () {
        // 1. Tự động khôi phục UI từ URL
        const params = new URLSearchParams(window.location.search);

        // Checkbox
        const catIds = params.get('categoryIds');
        if (catIds) {
            catIds.split(',').forEach(id => $('#cat_' + id).prop('checked', true));
        }

        // Giá & Sắp xếp
        if (params.get('maxPrice')) $('#priceRange').val(params.get('maxPrice'));
        $('#priceVal').text(parseInt($('#priceRange').val()).toLocaleString());
        $('#sortOrder').val(params.get('sortOrder'));

        // Cập nhật text giá khi kéo thanh trượt
        $('#priceRange').on('input', function() {
            $('#priceVal').text(parseInt(this.value).toLocaleString());
        });
    });

    // 2. Hàm gom tất cả dữ liệu và reload trang
    function applyFilters() {
        let cats = $('.cat-filter:checked').map(function() { return $(this).val(); }).get();
        let maxPrice = $('#priceRange').val();
        let sortOrder = $('#sortOrder').val();

        let url = window.location.pathname + '?';
        if (cats.length > 0) url += 'categoryIds=' + cats.join(',') + '&';
        url += 'maxPrice=' + maxPrice + '&sortOrder=' + sortOrder;

        window.location.href = url;
    }

    // 3. Xử lý thêm vào giỏ hàng qua AJAX
    $(document).on('click', '.btn-add-to-cart', function () {
        var productId = $(this).data('id');
        var token = $('#antiforgery-form input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: '@Url.Action("AddToCart", "Cart")',
            type: 'POST',
            data: { productId: productId, quantity: 1 },
            headers: { 'RequestVerificationToken': token },
            success: function (res) {
                if (res.success) {
                    alert("Đã thêm sản phẩm vào giỏ!");
                } else {
                    alert("Lỗi: " + res.message);
                }
            },
            error: function () {
                alert("Không thể kết nối máy chủ.");
            }
        });
    });
</script>