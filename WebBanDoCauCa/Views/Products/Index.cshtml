@model IEnumerable<WebBanDoCauCa.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng đồ câu";
    var categories = ViewBag.Categories as List<WebBanDoCauCa.Models.Category>
                     ?? new List<WebBanDoCauCa.Models.Category>();
    var categoryList = new SelectList(categories, "Id", "Name");
}

<style>
    .filter-box {
        position: sticky;
        top: 80px;
        z-index: 10;
    }
</style>

<div class="container mt-4">
    <h2 class="text-primary fw-bold text-uppercase mb-4">Cửa hàng</h2>

    <div class="row">

        <!-- FILTER -->
        <div class="col-md-3">
            <div class="card shadow-sm p-3 mb-4 filter-box">

                <h5 class="fw-bold">Bộ lọc</h5>
                <hr />

                <form method="get" asp-action="Index">

                    <!-- CATEGORY -->
                    <div class="mb-3">
                        <label class="fw-bold small">Loại sản phẩm</label>
                        <select name="categoryIds" class="form-select" asp-items="categoryList">
                            <option value="">-- Tất cả --</option>
                        </select>
                    </div>

                    <!-- PRICE RANGE -->
                    <div class="mb-3">
                        <label class="fw-bold small">
                            Giá tối đa:
                            <span id="priceVal" class="text-danger">
                                @ViewBag.MaxPrice.ToString("N0")
                            </span>đ
                        </label>

                        <input type="range"
                               name="maxPrice"
                               class="form-range"
                               min="@ViewBag.MinPrice"
                               max="@ViewBag.MaxPrice"
                               value="@ViewBag.MaxPrice"
                               oninput="document.getElementById('priceVal').innerText = parseInt(this.value).toLocaleString()">
                    </div>

                    <!-- SORT -->
                    <div class="mb-3">
                        <label class="fw-bold small">Sắp xếp</label>
                        <select name="sortOrder" class="form-select">
                            <option value="">Mới nhất</option>
                            <option value="price_asc">Giá tăng</option>
                            <option value="price_desc">Giá giảm</option>
                        </select>
                    </div>

                    <button class="btn btn-primary w-100">Lọc</button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">Reset</a>

                </form>
            </div>
        </div>

        <!-- PRODUCT LIST -->
        <div class="col-md-9">
            <div class="row">

                @if (!Model.Any())
                {
                    <p>Không có sản phẩm</p>
                }

                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">

                        <div class="card shadow-sm h-100">

                            <a asp-action="Details" asp-route-id="@item.Id">
                                <img src="@item.ImageUrl" class="card-img-top" />
                            </a>

                            <div class="card-body text-center">

                                <h6>@item.Name</h6>

                                <p class="text-danger fw-bold">
                                    @item.Price.ToString("N0") đ
                                </p>

                                <button class="btn btn-warning btn-add-to-cart"
                                        data-id="@item.Id">
                                    Thêm vào giỏ
                                </button>

                            </div>
                        </div>

                    </div>
                }

            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script>
        $('.btn-add-to-cart').click(function () {
            var productId = $(this).data('id');

            $.post('/Cart/AddToCart', { productId: productId, quantity: 1 }, function (res) {
                alert(res.success ? "Đã thêm vào giỏ" : "Lỗi");
            });
        });
    </script>
}