@model IEnumerable<WebBanDoCauCa.Models.Product>

@{
    ViewData["Title"] = "Cửa hàng đồ câu";
}

<div class="container mt-4">
    <div class="alert alert-secondary">
        User: @(User.Identity?.Name ?? "Chưa đăng nhập") |
        Admin Role: <strong>@User.IsInRole("Admin")</strong>
    </div>

    <div class="d-flex justify-content-between mb-4">
        <h2 class="text-primary fw-bold text-uppercase">@ViewData["CurrentCategory"]</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-success fw-bold">
                <i class="fa-solid fa-plus"></i> Thêm sản phẩm mới
            </a>
        }
    </div>

    <div class="row">
        <div class="col-md-3">
            @* Nội dung bộ lọc của bạn *@
        </div>

        <div class="col-md-9">
            <div class="row">
                @if (!Model.Any())
                {
                    <p class="text-center mt-5">Không tìm thấy sản phẩm nào trong cửa hàng.</p>
                }
                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100 shadow-sm border-0 product-card">
                            <div class="card-body text-center">
                                <h6 class="fw-bold">@item.Name</h6>
                                <p class="text-danger fw-bold">@item.Price.ToString("N0") VNĐ</p>

                                <div class="mt-auto d-grid gap-2">
                                    <button class="btn btn-warning btn-add-to-cart" data-id="@item.Id">Thêm vào giỏ</button>

                                    @if (User.IsInRole("Admin"))
                                    {
                                        <div class="btn-group mt-2">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Sửa</a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa</a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>