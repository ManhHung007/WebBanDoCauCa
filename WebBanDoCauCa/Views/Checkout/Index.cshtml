@model WebBanDoCauCa.Models.Order
@{
    ViewData["Title"] = "Thanh toán đơn hàng";
    var cartItems = ViewBag.CartItems as IEnumerable<WebBanDoCauCa.Models.CartItem> ?? new List<WebBanDoCauCa.Models.CartItem>();
}

<div class="container mt-5">
    <div class="row">
        @* Cột bên trái: Form nhập liệu *@
        <div class="col-md-7">
            <div class="card shadow-sm border-0 p-4">
                <h4 class="fw-bold text-primary mb-4 text-uppercase">Thông tin giao hàng</h4>
                <form id="orderForm" asp-action="Process" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ và tên người nhận</label>
                        <input asp-for="CustomerName" class="form-control form-control-lg" placeholder="Ví dụ: Nguyễn Văn A" required />
                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Số điện thoại</label>
                        <input asp-for="Phone" class="form-control form-control-lg" placeholder="09xxxxxxxx" required />
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Địa chỉ nhận hàng</label>
                        <textarea asp-for="Address" class="form-control" rows="3" placeholder="Số nhà, tên đường, xã/phường..." required></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Phương thức thanh toán</label>
                        <div class="form-check mb-2">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="methodCOD" value="COD" checked>
                            <label class="form-check-input-label fw-bold" for="methodCOD">
                                💵 Thanh toán khi nhận hàng (COD)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="paymentMethod" id="methodQR" value="QR">
                            <label class="form-check-input-label fw-bold" for="methodQR">
                                📱 Quét mã chuyển khoản QR (Demo Chuyển Khoản An Toàn)
                            </label>
                        </div>
                    </div>

                    <button type="button" id="btnSubmitOrder" class="btn btn-danger btn-lg w-100 fw-bold shadow-sm mt-3">
                        <i class="fa-solid fa-check-to-slot"></i> XÁC NHẬN ĐẶT HÀNG
                    </button>
                </form>
            </div>
        </div>

        @* Cột bên phải: Tóm tắt đơn hàng *@
        <div class="col-md-5">
            <div class="card bg-light border-0 p-4 shadow-sm">
                <h5 class="fw-bold border-bottom pb-2">Tóm tắt đơn hàng</h5>
                <div class="mt-3">
                    @foreach (var item in cartItems)
                    {
                        <div class="d-flex justify-content-between mb-2">
                            @* Sửa item.Product.Name thành item.Product?.Name *@
                            <span>@(item.Product?.Name ?? "Sản phẩm không tồn tại") (x@item.Quantity)</span>

                            @* Sửa item.Product.Price thành (item.Product?.Price ?? 0) *@
                            <span class="fw-bold">@((item.Quantity * (item.Product?.Price ?? 0)).ToString("N0")) đ</span>
                        </div>
                    }
                </div>
                <hr />
                <div class="d-flex justify-content-between">
                    <span class="h5 fw-bold">Tổng cộng:</span>
                    <span class="h4 fw-bold text-danger" id="totalAmountText">@ViewBag.Total.ToString("N0") VNĐ</span>
                </div>
            </div>
        </div>
    </div>
</div>

@* POP-UP MODAL GIẢ LẬP QUÉT MÃ QR *@
<div class="modal fade" id="qrModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="modal-header border-0 justify-content-center">
                <h5 class="modal-title fw-bold text-success text-uppercase">Hệ thống chuyển khoản QR</h5>
            </div>
            <div class="modal-body">
                <p class="text-muted small">Vui lòng quét mã QR bên dưới để thực hiện giao dịch thử nghiệm (Hệ thống giả lập an toàn)</p>

                <img src="https://api.qrserver.com/v1/create-qr-code/?size=250x250&data=Chuc-Mung-Ban-Da-Quet-Ma-Thanh-Cong-He-Thong-WebBanDoCauCa"
                     alt="Mã QR Demo" class="img-fluid my-3 shadow-sm rounded border p-2">

                <div class="alert alert-info py-2 small fw-bold">
                    Số tiền: @ViewBag.Total.ToString("N0") VNĐ <br />
                    Nội dung: Thanh toan don hang do cau
                </div>

                <div class="spinner-border text-primary spinner-border-sm me-2" role="status"></div>
                <span class="text-secondary small">Đang chờ hệ thống xác thực giao dịch...</span>
            </div>
            <div class="modal-footer border-0 d-grid gap-2">
                <button type="button" id="btnFakeSuccess" class="btn btn-success fw-bold">
                    ✅ [Demo] Giả lập quét tiền thành công
                </button>
                <button type="button" class="btn btn-light btn-sm text-muted" data-bs-dismiss="modal">Hủy giao dịch</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        $(document).ready(function () {
            var myModal = new bootstrap.Modal(document.getElementById('qrModal'));

            $('#btnSubmitOrder').click(function () {
                // Kiểm tra xem form nhập liệu đầy đủ thông tin chưa
                if (!$('#orderForm')[0].checkValidity()) {
                    $('#orderForm')[0].reportValidity();
                    return;
                }

                var selectedMethod = $('input[name="paymentMethod"]:checked').val();

                if (selectedMethod === 'QR') {
                    // Nếu chọn quét QR, mở Pop-up giả lập lên cho thầy cô/bạn bè xem giao diện
                    myModal.show();
                } else {
                    // Nếu chọn COD, submit form bình thường lên CheckoutController
                    $('#orderForm').submit();
                }
            });

            // Khi bấm vào nút giả lập thành công trên Pop-up
            $('#btnFakeSuccess').click(function () {
                myModal.hide();
                // Thực hiện gửi dữ liệu form đi, Backend xử lý lưu đơn hàng bình thường
                $('#orderForm').submit();
            });
        });
    </script>
}