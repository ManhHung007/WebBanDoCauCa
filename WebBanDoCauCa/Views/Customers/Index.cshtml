@model IEnumerable<WebBanDoCauCa.Models.ApplicationUser>

<div class="container mt-4">
    <h2 class="text-primary fw-bold">QUẢN LÝ KHÁCH HÀNG</h2>
    <table class="table table-hover mt-4">
        <thead class="table-light">
            <tr>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Địa chỉ</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@(user.FullName ?? "Chưa cập nhật")</td>
                    <td>@user.Email</td>
                    <td>@(user.Address ?? "Chưa cập nhật")</td>
                    <td>
                        <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info text-white">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning text-white">Sửa</a>
                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" style="display:inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa?');">
                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>